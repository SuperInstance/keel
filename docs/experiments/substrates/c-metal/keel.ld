/* Keel on the Metal — Linker Script for STM32F405 */
MEMORY
{
    FLASH (rx)  : ORIGIN = 0x08000000, LENGTH = 1M
    RAM   (rwx) : ORIGIN = 0x20000000, LENGTH = 128K
}

SECTIONS
{
    .vectors : { *(.vectors) } > FLASH
    .text    : { *(.text*) }   > FLASH
    .rodata  : { *(.rodata*) } > FLASH
    .bss     : { *(.bss*) }    > RAM
    .data    : { *(.data*) }   > RAM AT > FLASH
}
